datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model blog {
    blog_id String @id @default(auto()) @map("_id") @db.ObjectId
    blog_title String
    blog_description String
    blog_content String
    blog_created_by String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}